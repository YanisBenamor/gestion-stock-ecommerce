DB_DATABASE=gestion_stock_db
DB_USERNAME=stockflow
DB_PASSWORD=stockflow_pass
DB_ROOT_PASSWORD=root_pass

APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000

VITE_API_BASE_URL=/api
TZ=Europe/Paris

# ============================================
# Ollama LLM Configuration (Local, Autonomous)
# ============================================
# URL du service Ollama dans Docker
OLLAMA_URL=http://ollama:11434

# Modèle Ollama à utiliser
# Options légères: 'phi3' (~2GB), 'neural-chat' (~4GB), 'mistral' (~4GB)
# Options performantes: 'llama2' (~4GB), 'neural-chat' (~4GB)
# Défaut recommandé pour projet personnel: phi3 (rapide et léger)
OLLAMA_MODEL=phi3

# ============================================
# DEPRECATED - External API Keys (kept for fallback)
# ============================================
# Ces variables ne sont plus nécessaires
# Le système utilise maintenant Ollama local par défaut
# Laissez vides pour utiliser UNIQUEMENT Ollama

# GROQ_API_KEY=
# OPENAI_API_KEY=


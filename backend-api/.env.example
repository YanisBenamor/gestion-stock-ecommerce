APP_NAME="StockFlow B2B"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_KEY=
APP_CIPHER=AES-256-CBC

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ==========================================================
# DATABASE CONFIGURATION (MySQL in Docker)
# ==========================================================
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=gestion_stock_db
DB_USERNAME=stockflow
DB_PASSWORD=stockflow_pass

# ==========================================================
# CACHE & SESSION (Database)
# ==========================================================
CACHE_DRIVER=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ==========================================================
# QUEUE & BROADCAST
# ==========================================================
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# ==========================================================
# MAIL (optional - not needed for local setup)
# ==========================================================
MAIL_MAILER=log
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@stockflow.local
MAIL_FROM_NAME="${APP_NAME}"

# ==========================================================
# AWS & STORAGE (optional)
# ==========================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

FILESYSTEM_DISK=local

# ==========================================================
# SANCTUM/API AUTHENTICATION
# ==========================================================
SANCTUM_SKIPPED_MIDDLEWARE=throttle:60,1

# ==========================================================
# OLLAMA LLM CONFIGURATION (Local, 100% Autonomous)
# ==========================================================
# URL to Ollama API service (running in Docker container)
OLLAMA_URL=http://ollama:11434

# Model to use for AI generation
# Recommended (CPU): llama3.2:1b (very fast)
# Other options: phi3, llama2, mistral, neural-chat
OLLAMA_MODEL=llama3.2:1b

# ==========================================================
# OPTIONAL: External LLM APIs (Fallback only)
# Leave these empty to use local Ollama exclusively
# ==========================================================
# GROQ_API_KEY=
# OPENAI_API_KEY=

# ==========================================================
# REDIS (optional, for caching/sessions)
# ==========================================================
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==========================================================
# MISCELLANEOUS
# ==========================================================
TIMEZONE=Europe/Paris
LOCALE=fr_FR
FAKER_LOCALE=fr_FR
